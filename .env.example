# این فایل رو کپی کن به .env و مقادیر زیر رو پر کن:
#   cp .env.example .env

BOT_TOKEN=توکن_ربات_از_BotFather
BOT_USERNAME=username_ربات_بدون_@
GEMINI_API_KEY=کلید_API_از_aistudio.google.com
DEEPSEEK_API_KEY=کلید_API_از_platform.deepseek.com

# حداکثر درخواست به Gemini در هر دقیقه (پیش‌فرض: ۱۰۰)
GEMINI_RPM=100

# تنظیمات connection pool دیتابیس (پیش‌فرض‌ها برای بار متوسط مناسبن)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# اگه read replica داری، آدرسش رو اینجا بذار؛ وگرنه خالی بذار
# READ_DATABASE_URL=postgresql+asyncpg://melogap:melogap@replica-host:5432/melogap

# تنظیمات Webhook (اگه خالی بذاری polling استفاده می‌شه)
# WEBHOOK_URL=https://yourdomain.com/melogap_webhook
# WEBHOOK_SECRET=یه_رشته_تصادفی_بلند_برای_امنیت
# WEBHOOK_PORT=8080

# --- فقط برای اجرای دستی (بدون docker compose) لازمن ---
# وقتی با «docker compose up» اجرا می‌کنی، این دو مقدار توسط
# docker-compose.yml خودکار به سرویس‌های postgres/redis داخل شبکه‌ی
# داکر ست می‌شن و نیازی به تعریفشون در .env نیست.
# DATABASE_URL=postgresql+asyncpg://melogap:melogap@localhost:5432/melogap
# REDIS_URL=redis://localhost:6379/0
