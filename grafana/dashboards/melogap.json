{
  "title": "Blue Chat Bot",
  "uid": "melogap-bot",
  "schemaVersion": 38,
  "refresh": "15s",
  "tags": ["bot", "telegram", "melogap"],
  "style": "dark",
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "panels": [

    { "id": 100, "type": "row", "title": "⚡ وضعیت لحظه‌ای", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false },

    {
      "id": 1, "type": "stat", "title": "چت‌های فعال",
      "description": "تعداد جفت‌هایی که در این لحظه در حال گفتگو هستند",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 5},
      "targets": [{"expr": "bot_active_chats", "datasource": "Prometheus", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 100}, {"color": "orange", "value": 200}]}, "noValue": "0"}}
    },
    {
      "id": 2, "type": "stat", "title": "در صف انتظار",
      "description": "کاربران منتظر برای پیدا شدن همراه",
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 5},
      "targets": [{"expr": "bot_waiting_users", "datasource": "Prometheus", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": 0}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}, "noValue": "0"}}
    },
    {
      "id": 3, "type": "stat", "title": "صف AI",
      "description": "جاب‌های قضاوت در انتظار پردازش توسط worker",
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 5},
      "targets": [{"expr": "bot_ai_queue_size", "datasource": "Prometheus", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 20}, {"color": "red", "value": 50}]}, "noValue": "0"}}
    },
    {
      "id": 4, "type": "gauge", "title": "CPU",
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 5},
      "targets": [{"expr": "100 - (avg by(instance)(irate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "datasource": "Prometheus"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 60}, {"color": "orange", "value": 80}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 5, "type": "gauge", "title": "RAM",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 5},
      "targets": [{"expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "datasource": "Prometheus"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 60}, {"color": "orange", "value": 80}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 6, "type": "gauge", "title": "دیسک",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 5},
      "targets": [{"expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "datasource": "Prometheus"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "orange", "value": 85}, {"color": "red", "value": 95}]}}}
    },

    { "id": 101, "type": "row", "title": "👥 آمار کاربران", "gridPos": {"x": 0, "y": 6, "w": 24, "h": 1}, "collapsed": false },

    {
      "id": 14, "type": "stat", "title": "کل کاربران",
      "gridPos": {"x": 0, "y": 7, "w": 4, "h": 4},
      "targets": [{"expr": "pg_users_total_count", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "noValue": "0"}}
    },
    {
      "id": 15, "type": "stat", "title": "جدید ۲۴ ساعت",
      "gridPos": {"x": 4, "y": 7, "w": 4, "h": 4},
      "targets": [{"expr": "pg_users_total_new_today", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}, "noValue": "0"}}
    },
    {
      "id": 16, "type": "stat", "title": "جدید این هفته",
      "gridPos": {"x": 8, "y": 7, "w": 4, "h": 4},
      "targets": [{"expr": "pg_users_total_new_week", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}, "noValue": "0"}}
    },
    {
      "id": 17, "type": "stat", "title": "کل سکه‌ها",
      "gridPos": {"x": 12, "y": 7, "w": 4, "h": 4},
      "targets": [{"expr": "pg_total_coins_total", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "yellow", "mode": "fixed"}, "noValue": "0"}}
    },
    {
      "id": 18, "type": "piechart", "title": "توزیع جنسیت",
      "gridPos": {"x": 16, "y": 7, "w": 8, "h": 9},
      "targets": [{"expr": "pg_users_by_gender_count", "legendFormat": "{{gender}}", "datasource": "Prometheus"}],
      "options": {"pieType": "donut", "displayLabels": ["name", "percent"], "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}}
    },
    {
      "id": 19, "type": "barchart", "title": "کاربران به تفکیک استان",
      "gridPos": {"x": 0, "y": 11, "w": 16, "h": 9},
      "targets": [{"expr": "topk(15, pg_users_by_province_count)", "legendFormat": "{{province}}", "datasource": "Prometheus"}],
      "options": {"orientation": "horizontal", "xTickLabelRotation": 0, "barWidth": 0.7, "groupWidth": 0.7, "legend": {"displayMode": "hidden"}},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}}
    },
    {
      "id": 20, "type": "table", "title": "شهرهای برتر",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 8},
      "targets": [{"expr": "topk(30, pg_users_by_city_count)", "legendFormat": "{{city}} — {{province}}", "datasource": "Prometheus", "instant": true, "format": "table"}],
      "options": {"showHeader": true, "sortBy": [{"displayName": "Value", "desc": true}]},
      "transformations": [{"id": "organize", "options": {"renameByName": {"__name__": "", "city": "شهر", "province": "استان", "Value": "تعداد کاربر", "server": ""}}}],
      "fieldConfig": {"defaults": {"custom": {"align": "right"}, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}, {"color": "orange", "value": 50}]}}, "overrides": [{"matcher": {"id": "byName", "options": "تعداد کاربر"}, "properties": [{"id": "custom.displayMode", "value": "color-background"}, {"id": "custom.width", "value": 150}]}]}
    },

    { "id": 102, "type": "row", "title": "🤖 هوش مصنوعی و مدیریت", "gridPos": {"x": 0, "y": 28, "w": 24, "h": 1}, "collapsed": false },

    {
      "id": 21, "type": "stat", "title": "اخطار توسط DeepSeek",
      "description": "تعداد کل اخطارهایی که سیستم قضاوت DeepSeek صادر کرده",
      "gridPos": {"x": 0, "y": 29, "w": 4, "h": 5},
      "targets": [{"expr": "pg_warnings_total", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "orange", "mode": "fixed"}, "noValue": "0"}}
    },
    {
      "id": 22, "type": "stat", "title": "کل کاربران بن‌شده",
      "gridPos": {"x": 4, "y": 29, "w": 4, "h": 5},
      "targets": [{"expr": "pg_banned_users_total", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "noValue": "0"}}
    },
    {
      "id": 23, "type": "stat", "title": "بن توسط DeepSeek",
      "description": "کاربرانی که بعد از ۵ اخطار توسط DeepSeek به‌صورت خودکار بن شدند",
      "gridPos": {"x": 8, "y": 29, "w": 4, "h": 5},
      "targets": [{"expr": "pg_banned_users_by_deepseek", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "dark-orange", "mode": "fixed"}, "noValue": "0"}}
    },
    {
      "id": 24, "type": "stat", "title": "بن توسط Gemini",
      "description": "کاربران یونیک بن‌شده از طریق گزارش پروفایل توسط Gemini",
      "gridPos": {"x": 12, "y": 29, "w": 4, "h": 5},
      "targets": [{"expr": "pg_gemini_bans_unique_users_banned", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "purple", "mode": "fixed"}, "noValue": "0"}}
    },
    {
      "id": 25, "type": "stat", "title": "حکم Guilty توسط Gemini",
      "description": "تعداد کل احکام guilty در گزارش‌های پروفایل",
      "gridPos": {"x": 16, "y": 29, "w": 4, "h": 5},
      "targets": [{"expr": "pg_gemini_bans_profile_report_guilty", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "dark-purple", "mode": "fixed"}, "noValue": "0"}}
    },
    {
      "id": 26, "type": "timeseries", "title": "AI Jobs پردازش‌شده",
      "gridPos": {"x": 20, "y": 29, "w": 4, "h": 5},
      "targets": [
        {"expr": "rate(bot_ai_jobs_processed_total{type=\"chat_report\"}[5m])", "legendFormat": "DeepSeek", "datasource": "Prometheus"},
        {"expr": "rate(bot_ai_jobs_processed_total{type=\"profile_report\"}[5m])", "legendFormat": "Gemini", "datasource": "Prometheus"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 20, "lineWidth": 2}}}
    },

    { "id": 103, "type": "row", "title": "📈 ترافیک ربات", "gridPos": {"x": 0, "y": 34, "w": 24, "h": 1}, "collapsed": false },

    {
      "id": 7, "type": "timeseries", "title": "پیام‌های relay شده در ثانیه",
      "gridPos": {"x": 0, "y": 35, "w": 12, "h": 8},
      "targets": [{"expr": "rate(bot_messages_relayed_total[1m])", "legendFormat": "msg/s", "datasource": "Prometheus"}],
      "options": {"tooltip": {"mode": "single"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"fixedColor": "green", "mode": "fixed"}, "custom": {"fillOpacity": 25, "lineWidth": 2, "spanNulls": false}}}
    },
    {
      "id": 8, "type": "timeseries", "title": "چت شروع‌شده / پایان‌یافته",
      "gridPos": {"x": 12, "y": 35, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(bot_chats_started_total[5m])", "legendFormat": "شروع‌شده", "datasource": "Prometheus"},
        {"expr": "rate(bot_chats_ended_total[5m])", "legendFormat": "پایان‌یافته", "datasource": "Prometheus"}
      ],
      "options": {"tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"fillOpacity": 20, "lineWidth": 2}}, "overrides": [{"matcher": {"id": "byName", "options": "شروع‌شده"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "پایان‌یافته"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}
    },

    { "id": 106, "type": "row", "title": "🛡 آنتی اسپم", "gridPos": {"x": 0, "y": 43, "w": 24, "h": 1}, "collapsed": false },

    {
      "id": 200, "type": "stat", "title": "بلاک‌های اسپم (۲۴ ساعت)",
      "description": "تعداد کل درخواست‌هایی که spam guard در ۲۴ ساعت اخیر مسدود کرده",
      "gridPos": {"x": 0, "y": 44, "w": 6, "h": 5},
      "targets": [{"expr": "increase(bot_spam_blocks_total[24h])", "legendFormat": "", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}, "noValue": "0"}}
    },
    {
      "id": 201, "type": "stat", "title": "بلاک پیام (۱ ساعت)",
      "description": "پیام‌های متنی/مدیای مسدودشده در یک ساعت اخیر",
      "gridPos": {"x": 6, "y": 44, "w": 6, "h": 5},
      "targets": [{"expr": "increase(bot_spam_blocks_total{kind=\"message\"}[1h])", "legendFormat": "", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 20}, {"color": "red", "value": 100}]}, "noValue": "0"}}
    },
    {
      "id": 202, "type": "stat", "title": "بلاک callback (۱ ساعت)",
      "description": "callback‌ها و دستورات مسدودشده در یک ساعت اخیر",
      "gridPos": {"x": 12, "y": 44, "w": 6, "h": 5},
      "targets": [{"expr": "increase(bot_spam_blocks_total{kind=\"command\"}[1h])", "legendFormat": "", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 10}, {"color": "red", "value": 50}]}, "noValue": "0"}}
    },
    {
      "id": 203, "type": "stat", "title": "نرخ بلاک لحظه‌ای",
      "description": "میانگین تعداد بلاک‌های spam guard در هر دقیقه (rolling 5m)",
      "gridPos": {"x": 18, "y": 44, "w": 6, "h": 5},
      "targets": [{"expr": "rate(bot_spam_blocks_total[5m]) * 60", "legendFormat": "", "datasource": "Prometheus"}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 2}, {"color": "red", "value": 10}]}, "noValue": "0"}}
    },
    {
      "id": 204, "type": "timeseries", "title": "نرخ حملات اسپم در طول زمان",
      "description": "هر اسپایک در این نمودار نشان‌دهنده‌ی یک موج اسپم است",
      "gridPos": {"x": 0, "y": 49, "w": 24, "h": 8},
      "targets": [
        {"expr": "rate(bot_spam_blocks_total{kind=\"message\"}[1m])", "legendFormat": "پیام مسدودشده", "datasource": "Prometheus"},
        {"expr": "rate(bot_spam_blocks_total{kind=\"command\"}[1m])", "legendFormat": "callback مسدودشده", "datasource": "Prometheus"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"fillOpacity": 20, "lineWidth": 2, "spanNulls": false}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "پیام مسدودشده"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "callback مسدودشده"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}
        ]
      }
    },

    { "id": 104, "type": "row", "title": "🖥️ منابع سرور", "gridPos": {"x": 0, "y": 57, "w": 24, "h": 1}, "collapsed": false },

    {
      "id": 9, "type": "timeseries", "title": "CPU سرور",
      "gridPos": {"x": 0, "y": 58, "w": 8, "h": 8},
      "targets": [{"expr": "100 - (avg by(instance)(irate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "legendFormat": "CPU %", "datasource": "Prometheus"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"fixedColor": "orange", "mode": "fixed"}, "custom": {"thresholdsStyle": {"mode": "line"}, "fillOpacity": 20, "lineWidth": 2}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 85}]}}}
    },
    {
      "id": 10, "type": "timeseries", "title": "RAM سرور",
      "gridPos": {"x": 8, "y": 58, "w": 8, "h": 8},
      "targets": [
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "استفاده‌شده", "datasource": "Prometheus"},
        {"expr": "node_memory_MemTotal_bytes", "legendFormat": "کل", "datasource": "Prometheus"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"fillOpacity": 15, "lineWidth": 2}}, "overrides": [{"matcher": {"id": "byName", "options": "کل"}, "properties": [{"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}, {"id": "color", "value": {"fixedColor": "gray", "mode": "fixed"}}]}]}
    },
    {
      "id": 11, "type": "timeseries", "title": "Redis حافظه",
      "gridPos": {"x": 16, "y": 58, "w": 8, "h": 8},
      "targets": [{"expr": "redis_memory_used_bytes", "legendFormat": "used", "datasource": "Prometheus"}],
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"fixedColor": "red", "mode": "fixed"}, "custom": {"fillOpacity": 20, "lineWidth": 2}}}
    },

    { "id": 105, "type": "row", "title": "🗄️ دیتابیس", "gridPos": {"x": 0, "y": 66, "w": 24, "h": 1}, "collapsed": false },

    {
      "id": 12, "type": "timeseries", "title": "اتصالات فعال PostgreSQL",
      "gridPos": {"x": 0, "y": 67, "w": 12, "h": 8},
      "targets": [{"expr": "pg_stat_activity_count", "legendFormat": "connections", "datasource": "Prometheus"}],
      "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "custom": {"fillOpacity": 20, "lineWidth": 2}}}
    },
    {
      "id": 27, "type": "timeseries", "title": "Redis — دستورات در ثانیه",
      "gridPos": {"x": 12, "y": 67, "w": 12, "h": 8},
      "targets": [{"expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "cmd/s", "datasource": "Prometheus"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"fixedColor": "red", "mode": "fixed"}, "custom": {"fillOpacity": 20, "lineWidth": 2}}}
    }

  ]
}
